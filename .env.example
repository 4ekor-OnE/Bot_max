# Скопируйте в .env и заполните значения
BOT_TOKEN=
# или MAX_BOT_TOKEN=

# Пароль для команды /admin <пароль> (dev). В production задайте хеш:
# ADMIN_PASSWORD_HASH=<sha256 hex в нижнем регистре>
ADMIN_PASSWORD=admin

DATABASE_URL=sqlite:///support_bot.db

# Веб-админка Flask: python -m web_admin
# WEB_ADMIN_SECRET_KEY=<случайная длинная строка для сессий>
# WEB_ADMIN_HOST=127.0.0.1
# WEB_ADMIN_PORT=5000
# WEB_ADMIN_DEBUG=0

# Каталоги данных (по умолчанию ./data/instructions и ./data/temp)
# INSTRUCTIONS_DIR=
# TEMP_FILES_DIR=
# INSTRUCTION_MAX_BYTES=20971520
# Фото к заявкам (копия на диск для панели управления)
# TICKET_PHOTOS_DIR=
# TICKET_PHOTO_MAX_BYTES=15728640
